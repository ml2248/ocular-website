<script>
  // ── Nav scroll effect ──
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav.style.borderBottomColor = 'rgba(26,39,68,0.8)';
      nav.style.background = 'rgba(6,7,15,0.92)';
      nav.style.backdropFilter = 'blur(16px)';
    } else {
      nav.style.borderBottomColor = 'rgba(26,39,68,0)';
      nav.style.background = 'rgba(6,7,15,0)';
      nav.style.backdropFilter = 'blur(0)';
    }
  });

  // ── Language toggle ──
  let currentLang = 'de';
  const langToggle = document.getElementById('lang-toggle');
  const langLabel  = document.getElementById('lang-label');

  function applyLang(lang) {
    currentLang = lang;
    langLabel.textContent = lang === 'de' ? 'EN' : 'DE';
    document.documentElement.lang = lang;

    // Update all data-de / data-en elements
    document.querySelectorAll('[data-de],[data-en]').forEach(el => {
      const text = el.getAttribute('data-' + lang);
      if (!text) return;
      // If it contains HTML tags, use innerHTML, otherwise textContent
      if (text.includes('<')) {
        el.innerHTML = text;
      } else {
        el.textContent = text;
      }
    });

    // Update contact input placeholders
    document.querySelectorAll('.contact-input').forEach(el => {
      const ph = el.getAttribute('data-placeholder-' + lang);
      if (ph) el.placeholder = ph;
    });
  }

  langToggle.addEventListener('click', () => {
    applyLang(currentLang === 'de' ? 'en' : 'de');
  });
</script>

</body>
</html>
