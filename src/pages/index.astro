---
import '../styles/global.css'
---

<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>Ocular — SOC Intelligence Platform</title>
  <meta name="description" content="Die Intelligence-Plattform für SOC-Analysten. IOC-Triage, Threat Hunting, KQL-Generierung — ohne Tab-Wechsel." />
  <link rel="icon" href="/favicon.ico" />
  <meta property="og:title" content="Ocular — SOC Intelligence Platform" />
  <meta property="og:description" content="Schneller triagieren. Smarter jagen. Gebaut von Analysten, für Analysten." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://ocular-soc.com" />
  <meta property="og:image" content="https://ocular-soc.com/screenshot.png" />
</head>

<body style="background-color:#06070f; overflow-x:hidden;">

<!-- ── BACKGROUND LAYERS ── -->
<div style="position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:radial-gradient(circle, rgba(20,184,166,0.045) 1px, transparent 1px);
  background-size:28px 28px;"></div>
<div style="position:fixed;top:0;left:0;right:0;height:600px;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 80% 50% at 50% -10%, rgba(20,184,166,0.1) 0%, transparent 70%);"></div>

<!-- ── NAV ── -->
<nav id="nav" style="position:fixed;top:0;left:0;right:0;z-index:50;
     border-bottom:1px solid rgba(26,39,68,0);
     background:rgba(6,7,15,0);
     backdrop-filter:blur(0);
     transition:all 0.3s ease;padding:0 24px;">
  <div style="max-width:1100px;margin:0 auto;height:60px;display:flex;align-items:center;justify-content:space-between;">

    <!-- Logo -->
    <div style="display:flex;align-items:center;gap:10px;">
      <div style="width:32px;height:32px;border-radius:3px;display:flex;align-items:center;justify-content:center;
                  background:linear-gradient(135deg,#0b2020,#0d1f2e);border:1px solid rgba(94,234,212,0.2);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#5eead4" stroke-width="1.5">
          <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
      </div>
      <span style="color:#fff;font-weight:800;font-size:15px;letter-spacing:0.2em;font-family:'Inter',sans-serif;">OCULAR</span>
    </div>

    <!-- Nav links -->
    <div style="display:flex;align-items:center;gap:8px;">
      <a href="#features" class="nav-link" data-de="Features" data-en="Features">Features</a>
      <a href="#video" class="nav-link" data-de="Demo" data-en="Demo">Demo</a>
      <a href="#security" class="nav-link" data-de="Sicherheit" data-en="Security">Sicherheit</a>

      <!-- Language toggle -->
      <button id="lang-toggle"
        style="display:flex;align-items:center;gap:6px;background:rgba(26,39,68,0.6);border:1px solid #1a2744;
               border-radius:2px;padding:6px 12px;color:#94a3b8;font-size:12px;font-weight:600;
               letter-spacing:0.06em;cursor:pointer;transition:all 0.2s;font-family:'Inter',sans-serif;">
        <span style="font-size:14px;">🌐</span>
        <span id="lang-label">EN</span>
      </button>

      <a href="https://demo.ocular-soc.com" target="_blank" class="nav-link" data-de="Live Demo" data-en="Live Demo">Live Demo</a>
      <a href="#contact"
         style="background:#14b8a6;color:#fff;font-size:12px;font-weight:700;padding:8px 18px;
                border-radius:2px;letter-spacing:0.1em;text-decoration:none;transition:background 0.2s;
                font-family:'Inter',sans-serif;"
         onmouseover="this.style.background='#0d9488'" onmouseout="this.style.background='#14b8a6'"
         class="nav-cta" data-de="Zugang anfragen" data-en="Request Access">Zugang anfragen</a>
    </div>
  </div>
</nav>

<!-- ── HERO ── -->
<section style="position:relative;z-index:1;padding:160px 24px 80px;text-align:center;">

  <div style="max-width:860px;margin:0 auto;">

    <!-- Eyebrow badge -->
    <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;
                border-radius:100px;border:1px solid rgba(20,184,166,0.25);
                background:rgba(20,184,166,0.06);margin-bottom:32px;">
      <span style="width:6px;height:6px;border-radius:50%;background:#5eead4;animation:pulse 2s infinite;display:block;"></span>
      <span style="color:#5eead4;font-size:11px;font-weight:700;letter-spacing:0.16em;"
            data-de="GEBAUT FÜR SOC-ANALYSTEN" data-en="BUILT FOR SOC ANALYSTS">GEBAUT FÜR SOC-ANALYSTEN</span>
    </div>

    <!-- Headline -->
    <h1 style="font-size:clamp(2.4rem,5.5vw,4.2rem);font-weight:900;line-height:1.05;
               letter-spacing:-0.03em;color:#fff;margin-bottom:24px;">
      <span data-de="Schluss mit Tab-Chaos." data-en="Stop switching tabs.">Schluss mit Tab-Chaos.</span><br/>
      <span style="background:linear-gradient(135deg,#5eead4 0%,#38bdf8 50%,#818cf8 100%);
                   -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"
            data-de="Start mit echtem Hunting." data-en="Start hunting threats.">Start mit echtem Hunting.</span>
    </h1>

    <!-- Sub -->
    <p style="font-size:clamp(1rem,2.2vw,1.25rem);color:#64748b;max-width:560px;margin:0 auto 40px;line-height:1.75;"
       data-de="Ocular vereint IOC-Triage, Threat Hunting und KQL-Generierung in einer Plattform — ohne den Browser zu verlassen."
       data-en="Ocular unifies IOC triage, threat hunting, and KQL generation in one platform — without leaving the browser.">
      Ocular vereint IOC-Triage, Threat Hunting und KQL-Generierung in einer Plattform — ohne den Browser zu verlassen.
    </p>

    <!-- CTAs -->
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:80px;">
      <a href="#contact"
         style="display:inline-flex;align-items:center;gap:8px;background:#14b8a6;color:#fff;
                font-size:13px;font-weight:700;padding:14px 32px;border-radius:2px;letter-spacing:0.1em;
                text-decoration:none;transition:background 0.2s;font-family:'Inter',sans-serif;"
         onmouseover="this.style.background='#0d9488'" onmouseout="this.style.background='#14b8a6'"
         class="hero-cta-primary"
         data-de="Demo vereinbaren" data-en="Book a Demo">
        Demo vereinbaren
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="https://demo.ocular-soc.com" target="_blank"
         style="display:inline-flex;align-items:center;gap:8px;background:transparent;color:#94a3b8;
                font-size:13px;font-weight:600;padding:14px 32px;border-radius:2px;
                border:1px solid #1a2744;letter-spacing:0.08em;text-decoration:none;
                transition:all 0.2s;font-family:'Inter',sans-serif;"
         onmouseover="this.style.borderColor='#334155';this.style.color='#e2e8f0'"
         onmouseout="this.style.borderColor='#1a2744';this.style.color='#94a3b8'"
         class="hero-cta-secondary"
         data-de="Live Demo öffnen →" data-en="Try Live Demo →">
        Live Demo öffnen →
      </a>
    </div>
  </div>

  <!-- ── APP SCREENSHOT ── -->
  <div style="position:relative;max-width:1060px;margin:0 auto;">

    <!-- Glow ring behind screenshot -->
    <div style="position:absolute;inset:-40px;pointer-events:none;
      background:radial-gradient(ellipse 70% 50% at 50% 60%, rgba(20,184,166,0.08) 0%, transparent 70%);"></div>

    <!-- Browser frame -->
    <div style="position:relative;border-radius:6px;overflow:hidden;
                border:1px solid rgba(26,39,68,0.9);
                box-shadow:0 0 0 1px rgba(20,184,166,0.05),
                           0 32px 80px rgba(0,0,0,0.7),
                           0 0 120px rgba(20,184,166,0.06);">

      <!-- Browser chrome -->
      <div style="display:flex;align-items:center;gap:8px;padding:0 16px;height:36px;
                  background:#070c15;border-bottom:1px solid #0f1829;">
        <div style="display:flex;gap:6px;">
          <span style="width:10px;height:10px;border-radius:50%;background:#1e293b;display:block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#1e293b;display:block;"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#1e293b;display:block;"></span>
        </div>
        <div style="flex:1;max-width:340px;margin:0 auto;">
          <div style="height:22px;border-radius:3px;background:#06070f;border:1px solid #0f1829;
                      display:flex;align-items:center;padding:0 12px;gap:6px;">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#1e293b" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            <span style="color:#334155;font-size:10px;font-family:'JetBrains Mono',monospace;">app.ocular-soc.com/scope</span>
          </div>
        </div>
      </div>

      <!-- Screenshot -->
      <img src="/screenshot.png" alt="Ocular Scope — IOC Investigation"
           style="width:100%;display:block;image-rendering:auto;" />
    </div>

    <!-- Bottom fade -->
    <div style="position:absolute;bottom:0;left:0;right:0;height:120px;pointer-events:none;
      background:linear-gradient(to top, #06070f 0%, transparent 100%);border-radius:0 0 6px 6px;"></div>
  </div>
</section>

<!-- ── STATS BAR ── -->
<section style="position:relative;z-index:1;padding:48px 24px;border-top:1px solid #0f1829;border-bottom:1px solid #0f1829;
                background:rgba(12,18,32,0.4);">
  <div style="max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center;">
    <div>
      <div style="font-size:2.2rem;font-weight:900;color:#fff;font-variant-numeric:tabular-nums;line-height:1;">18+</div>
      <div style="font-size:11px;color:#334155;letter-spacing:0.1em;margin-top:6px;"
           data-de="THREAT-HUNT-MODULE" data-en="THREAT HUNT MODULES">THREAT-HUNT-MODULE</div>
    </div>
    <div>
      <div style="font-size:2.2rem;font-weight:900;color:#fff;font-variant-numeric:tabular-nums;line-height:1;">230+</div>
      <div style="font-size:11px;color:#334155;letter-spacing:0.1em;margin-top:6px;"
           data-de="VALIDIERTE KQL-QUERIES" data-en="VALIDATED KQL QUERIES">VALIDIERTE KQL-QUERIES</div>
    </div>
    <div>
      <div style="font-size:2.2rem;font-weight:900;
                  background:linear-gradient(135deg,#5eead4,#38bdf8);
                  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
                  line-height:1;">100%</div>
      <div style="font-size:11px;color:#334155;letter-spacing:0.1em;margin-top:6px;"
           data-de="MICROSOFT NATIVE SSO" data-en="MICROSOFT NATIVE SSO">MICROSOFT NATIVE SSO</div>
    </div>
    <div>
      <div style="font-size:2.2rem;font-weight:900;color:#fff;font-variant-numeric:tabular-nums;line-height:1;">0</div>
      <div style="font-size:11px;color:#334155;letter-spacing:0.1em;margin-top:6px;"
           data-de="GETEILTE INFRASTRUKTUR" data-en="SHARED INFRASTRUCTURE">GETEILTE INFRASTRUKTUR</div>
    </div>
  </div>
</section>

<!-- ── PROBLEM ── -->
<section style="position:relative;z-index:1;padding:100px 24px;">
  <div style="max-width:720px;margin:0 auto;text-align:center;">
    <div class="section-label" data-de="DAS PROBLEM" data-en="THE PROBLEM">DAS PROBLEM</div>
    <h2 class="section-heading"
        data-de="Ein SOC-Analyst jongliert pro Incident mit 12+ Browser-Tabs"
        data-en="A typical SOC analyst juggles 12+ browser tabs per investigation">
      Ein SOC-Analyst jongliert pro Incident mit 12+ Browser-Tabs
    </h2>
    <p style="color:#475569;font-size:15px;line-height:1.85;margin-top:16px;"
       data-de="VirusTotal. AbuseIPDB. Shodan. NVD. MITRE ATT&amp;CK. Microsoft Sentinel. Jeder Lookup ist ein Kontextwechsel. Jeder Kontextwechsel kostet Momentum. Wenn eine echte Bedrohung sich schnell bewegt, dürfen die Tools nicht bremsen."
       data-en="VirusTotal. AbuseIPDB. Shodan. NVD. MITRE ATT&amp;CK. Sentinel. Every lookup is a context switch. Every context switch kills momentum. When a real threat is moving fast, your tools shouldn't slow you down.">
      VirusTotal. AbuseIPDB. Shodan. NVD. MITRE ATT&amp;CK. Microsoft Sentinel. Jeder Lookup ist ein Kontextwechsel. Jeder Kontextwechsel kostet Momentum. Wenn eine echte Bedrohung sich schnell bewegt, dürfen die Tools nicht bremsen.
    </p>
  </div>

  <!-- Pain cards -->
  <div style="max-width:960px;margin:56px auto 0;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
    <div class="pain-card">
      <div class="pain-icon">⏱</div>
      <h3 class="pain-title" data-de="Manuelle IOC-Triage" data-en="Manual IOC Triage">Manuelle IOC-Triage</h3>
      <p class="pain-body"
         data-de="Copy-paste über 5 Tools für eine einzige IP. Multipliziert mit 20 Alerts pro Schicht."
         data-en="Copy-paste across 5 tools to verdict a single IP. Multiply by 20 alerts per shift.">
        Copy-paste über 5 Tools für eine einzige IP. Multipliziert mit 20 Alerts pro Schicht.
      </p>
    </div>
    <div class="pain-card">
      <div class="pain-icon">🔍</div>
      <h3 class="pain-title" data-de="Kein einheitlicher Kontext" data-en="No Unified Context">Kein einheitlicher Kontext</h3>
      <p class="pain-body"
         data-de="Geolokation in einem Tab, Reputation im nächsten, offene Ports im dritten. Kein Analyst sollte das manuell zusammenfügen."
         data-en="Geolocation in one tab, reputation in another, open ports in a third. No analyst should stitch that together manually.">
        Geolokation in einem Tab, Reputation im nächsten, offene Ports im dritten. Kein Analyst sollte das manuell zusammenfügen.
      </p>
    </div>
    <div class="pain-card">
      <div class="pain-icon">📝</div>
      <h3 class="pain-title" data-de="KQL von Grund auf" data-en="KQL from Scratch">KQL von Grund auf</h3>
      <p class="pain-body"
         data-de="Sentinel-Queries für jeden Hunt neu schreiben kostet Stunden. Analysten sollten keine Syntax-Engineers sein."
         data-en="Writing Sentinel queries for every hunt wastes hours. Analysts shouldn't be syntax engineers.">
        Sentinel-Queries für jeden Hunt neu schreiben kostet Stunden. Analysten sollten keine Syntax-Engineers sein.
      </p>
    </div>
  </div>
</section>

<!-- ── FEATURES ── -->
<section id="features" style="position:relative;z-index:1;padding:100px 24px;border-top:1px solid #0f1829;">
  <div style="max-width:1000px;margin:0 auto;">

    <div style="text-align:center;margin-bottom:64px;">
      <div class="section-label" data-de="WAS OCULAR MACHT" data-en="WHAT OCULAR DOES">WAS OCULAR MACHT</div>
      <h2 class="section-heading"
          data-de="Alle Tools, die ein Analyst braucht. Eine Plattform."
          data-en="Every tool an analyst needs. One platform.">
        Alle Tools, die ein Analyst braucht. Eine Plattform.
      </h2>
    </div>

    <!-- Feature rows -->
    <div style="display:flex;flex-direction:column;gap:16px;">

      <!-- IOC -->
      <div class="feature-row">
        <div class="feature-row-content">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <span style="padding:3px 10px;border-radius:2px;font-size:10px;font-weight:700;letter-spacing:0.1em;
                         color:#f87171;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);">IOC</span>
            <h3 class="feature-title"
                data-de="Sofortige IOC-Intelligence" data-en="Instant IOC Intelligence">
              Sofortige IOC-Intelligence
            </h3>
          </div>
          <p class="feature-body"
             data-de="IP, Domain, Datei-Hash, URL — einen Indikator einfügen und in Sekunden Reputation, Geolokation, ASN, offene Ports, Malware-Familien und C2-Signale erhalten. Batch-Check für Dutzende gleichzeitig."
             data-en="IP, domain, file hash, URL — paste any indicator and get reputation, geolocation, ASN, open ports, malware families, and C2 signals in seconds. Batch-check dozens at once.">
            IP, Domain, Datei-Hash, URL — einen Indikator einfügen und in Sekunden Reputation, Geolokation, ASN, offene Ports, Malware-Familien und C2-Signale erhalten. Batch-Check für Dutzende gleichzeitig.
          </p>
        </div>
        <ul class="feature-list">
          <li class="feature-item" data-de="IP · Domain · Hash · URL · E-Mail" data-en="IP · Domain · Hash · URL · Email">IP · Domain · Hash · URL · E-Mail</li>
          <li class="feature-item" data-de="Shodan · BGP/ASN · SSL-Zertifikate" data-en="Shodan · BGP/ASN · SSL Certs">Shodan · BGP/ASN · SSL-Zertifikate</li>
          <li class="feature-item" data-de="Batch-Check — 50 IOCs parallel" data-en="Batch Check — 50 IOCs in parallel">Batch-Check — 50 IOCs parallel</li>
          <li class="feature-item" data-de="IOC Memory cross-session" data-en="IOC memory across sessions">IOC Memory cross-session</li>
        </ul>
      </div>

      <!-- HUNT -->
      <div class="feature-row">
        <div class="feature-row-content">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <span style="padding:3px 10px;border-radius:2px;font-size:10px;font-weight:700;letter-spacing:0.1em;
                         color:#a78bfa;background:rgba(139,92,246,0.08);border:1px solid rgba(139,92,246,0.2);">HUNT</span>
            <h3 class="feature-title"
                data-de="KQL Threat Hunt Generator" data-en="KQL Threat Hunt Generator">
              KQL Threat Hunt Generator
            </h3>
          </div>
          <p class="feature-body"
             data-de="230+ validierte Microsoft Sentinel Queries in 44 Huntbooks. IOC-Kontext hinzufügen, fertige KQL mit vorausgefüllten Substitutionen erhalten. Keine Syntaxfehler, kein Raten."
             data-en="230+ validated Microsoft Sentinel queries across 44 huntbooks. Add your IOC context, get ready-to-paste KQL with substitution fields pre-filled. No syntax errors, no guesswork.">
            230+ validierte Microsoft Sentinel Queries in 44 Huntbooks. IOC-Kontext hinzufügen, fertige KQL mit vorausgefüllten Substitutionen erhalten. Keine Syntaxfehler, kein Raten.
          </p>
        </div>
        <ul class="feature-list">
          <li class="feature-item" data-de="44 Huntbooks — vollständiges MITRE ATT&amp;CK" data-en="44 Huntbooks — full MITRE ATT&amp;CK">44 Huntbooks — vollständiges MITRE ATT&amp;CK</li>
          <li class="feature-item" data-de="230+ validierte Sentinel-Queries" data-en="230+ validated Sentinel queries">230+ validierte Sentinel-Queries</li>
          <li class="feature-item" data-de="Auto-Substitution für IP, Domain, Hash, User" data-en="Auto-substitution for IP, Domain, Hash, User">Auto-Substitution für IP, Domain, Hash, User</li>
          <li class="feature-item" data-de="Direkt in Sentinel einfügen" data-en="One-click copy into Sentinel">Direkt in Sentinel einfügen</li>
        </ul>
      </div>

      <!-- UTIL -->
      <div class="feature-row">
        <div class="feature-row-content">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
            <span style="padding:3px 10px;border-radius:2px;font-size:10px;font-weight:700;letter-spacing:0.1em;
                         color:#94a3b8;background:rgba(148,163,184,0.08);border:1px solid rgba(148,163,184,0.2);">UTIL</span>
            <h3 class="feature-title"
                data-de="Analyst Utilities" data-en="Analyst Utilities">
              Analyst Utilities
            </h3>
          </div>
          <p class="feature-body"
             data-de="Die kleinen Tools, die jeweils 10 Minuten sparen — E-Mail-Header-Parsing, LOtL-Binär-Analyse, CVE-Suche mit EPSS-Scoring, Decoder für obfuskierte Payloads und mehr."
             data-en="The small tools that save 10 minutes each — email header parsing, LOtL binary analysis, CVE lookup with EPSS scoring, decoder for obfuscated payloads, and more.">
            Die kleinen Tools, die jeweils 10 Minuten sparen — E-Mail-Header-Parsing, LOtL-Binär-Analyse, CVE-Suche mit EPSS-Scoring, Decoder für obfuskierte Payloads und mehr.
          </p>
        </div>
        <ul class="feature-list">
          <li class="feature-item" data-de="E-Mail-Header Analyzer (SPF/DKIM/DMARC)" data-en="Email Header Analyzer (SPF/DKIM/DMARC)">E-Mail-Header Analyzer (SPF/DKIM/DMARC)</li>
          <li class="feature-item" data-de="LOtL Analyzer — certutil, mshta, rundll32..." data-en="LOtL Analyzer — certutil, mshta, rundll32...">LOtL Analyzer — certutil, mshta, rundll32...</li>
          <li class="feature-item" data-de="CVE-Suche + CISA KEV + EPSS Score" data-en="CVE Search + CISA KEV + EPSS Score">CVE-Suche + CISA KEV + EPSS Score</li>
          <li class="feature-item" data-de="Base64 · Hex · JWT · XOR Decoder" data-en="Base64 · Hex · JWT · XOR Decoder">Base64 · Hex · JWT · XOR Decoder</li>
        </ul>
      </div>

    </div>
  </div>
</section>

<!-- ── KQL CODE DEMO ── -->
<section style="position:relative;z-index:1;padding:80px 24px;border-top:1px solid #0f1829;
                background:rgba(7,11,18,0.6);">
  <div style="max-width:960px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">

    <div>
      <div class="section-label" data-de="KQL — READY TO HUNT" data-en="KQL — READY TO HUNT">KQL — READY TO HUNT</div>
      <h2 style="font-size:1.8rem;font-weight:800;color:#fff;line-height:1.2;margin:12px 0 16px;"
          data-de="Von IOC zu Sentinel-Query in Sekunden" data-en="From IOC to Sentinel query in seconds">
        Von IOC zu Sentinel-Query in Sekunden
      </h2>
      <p style="color:#475569;font-size:14px;line-height:1.8;"
         data-de="Indikator einfügen → Huntbook wählen → fertige Query kopieren. Ocular füllt alle Platzhalter automatisch mit deinem IOC-Kontext."
         data-en="Paste an indicator → select a huntbook → copy the ready query. Ocular auto-fills all substitutions from your IOC context.">
        Indikator einfügen → Huntbook wählen → fertige Query kopieren. Ocular füllt alle Platzhalter automatisch mit deinem IOC-Kontext.
      </p>
    </div>

    <!-- Code block -->
    <div style="border-radius:4px;overflow:hidden;border:1px solid #1a2744;box-shadow:0 0 40px rgba(0,0,0,0.5);">
